# Secrets / config
.env

# Large data (exceeds GitHub's 100 MB file limit) - regenerate / download
data_jobs.csv
data/*.csv

# Large model binaries (806 MB stacking model) - regenerate via training
outputs/models/*
*.pkl
*.cbm
mlruns/
catboost_info/

# ...but DO ship the compact deployable models so the repo works out-of-the-box
# (LightGBM ~1.3 MB + two quantile models ~3 MB each). Negations must come last.
!outputs/models/best_model.joblib
!outputs/models/quantile_lower.joblib
!outputs/models/quantile_upper.joblib

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Run logs
*.log

# OS / IDE
.DS_Store
.ipynb_checkpoints/

# Office temporary lock files
~$*

